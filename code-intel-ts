#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SUBCOMMAND="${1:-}"
if [[ -z "$SUBCOMMAND" ]]; then
  echo "usage: code-intel-ts <ast|lsp> ..." >&2
  exit 1
fi
shift
case "$SUBCOMMAND" in
  ast)
    exec bun "$SCRIPT_DIR/ast.ts" "$@"
    ;;
  lsp)
    exec bun "$SCRIPT_DIR/lsp.ts" "$@"
    ;;
  *)
    echo "unknown subcommand: $SUBCOMMAND" >&2
    exit 1
    ;;
esac
